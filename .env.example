# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=newscore

# Redis
REDIS_URL=redis://redis:6379

# JWT — rotate JWT_SECRET in production; use a long random value (32+ chars).
# Consider RS256 if services deploy independently.
JWT_SECRET=replace-with-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Media
MEDIA_ROOT=/media
MEDIA_BASE_URL=http://localhost:3000
MAX_FILE_SIZE_MB=50

# CORS (comma-separated origins; unset = allow * for local dev)
# CORS_ORIGINS=http://localhost:3000,https://news.example.com

# GraphQL router (production: ROUTER_CONFIG=/config/router.prod.yaml)
# FRONTEND_ORIGIN=http://localhost:3000

# Dev seed — set ALLOW_DEV_SEED=false in production
ALLOW_DEV_SEED=true
SEED_ADMIN_EMAIL=admin@newscore.local
SEED_ADMIN_PASSWORD=change-me-in-production

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Frontend
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
# Server-side GraphQL from the frontend container (docker compose sets this automatically)
GRAPHQL_INTERNAL_URL=http://graphql_router:4000/graphql
# Prefer versioned REST paths via Nginx in production (http://localhost/api/v1/...)
NEXT_PUBLIC_ADMIN_API_URL=http://localhost/api/v1/admin
NEXT_PUBLIC_NEWS_API_URL=http://localhost/api/v1/news
NEXT_PUBLIC_LAYOUT_API_URL=http://localhost/api/v1/layout

# Media storage: local (default) or s3
MEDIA_STORAGE_BACKEND=local
# MEDIA_BASE_URL=https://cdn.example.com
# S3_BUCKET=newscore-media
# S3_REGION=us-east-1
# S3_ENDPOINT_URL=
# S3_PUBLIC_BASE_URL=https://cdn.example.com
# NEXT_PUBLIC_MEDIA_CDN_HOST=cdn.example.com

# MongoDB
MONGO_URI=mongodb://mongodb:27017
MONGO_DB_NAME=newscore

# Redis
REDIS_URL=redis://redis:6379

# JWT
JWT_SECRET=replace-with-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Media
MEDIA_ROOT=/media
MEDIA_BASE_URL=http://localhost:3000
MAX_FILE_SIZE_MB=50

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=text

# Frontend
NEXT_PUBLIC_GRAPHQL_URL=http://localhost:4000/graphql
# Server-side GraphQL from the frontend container (docker compose sets this automatically)
GRAPHQL_INTERNAL_URL=http://graphql_router:4000/graphql
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:5001
NEXT_PUBLIC_NEWS_API_URL=http://localhost:5002
NEXT_PUBLIC_LAYOUT_API_URL=http://localhost:5003
